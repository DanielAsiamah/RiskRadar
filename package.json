{
  "name": "riskradar-expo",
  "version": "1.0.0",
  "description": "Open-source UK postcode, point, and area crime intelligence explorer.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanielAsiamah/RiskRadar.git"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@types/leaflet": "^1.9.21",
    "expo": "~54.0.35",
    "expo-constants": "~18.0.13",
    "expo-location": "~19.0.8",
    "expo-status-bar": "~3.0.9",
    "leaflet": "^1.9.4",
    "lucide-react-native": "^1.22.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-leaflet": "^5.0.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "twrnc": "^4.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "api": "node backend/server.mjs",
    "api:crime-dataset-summary": "node backend/crime-dataset-summary.mjs",
    "api:crime-score-calibration": "node backend/crime-score-calibration.mjs",
    "api:crime-source-check": "node backend/crime-source-check.mjs",
    "api:score-test": "node --test backend/crime-score.test.mjs",
    "api:concurrency-test": "node --test backend/bounded-concurrency.test.mjs",
    "api:import-crime-snapshots": "node backend/import-crime-snapshots.mjs",
    "api:prewarm": "node backend/prewarm.mjs",
    "api:smoke": "node backend/smoke-test.mjs",
    "api:verify": "node backend/verify.mjs",
    "test": "npm run typecheck && npm run test:backend",
    "test:backend": "node --check backend/server.mjs && node --test backend/*.test.mjs",
    "typecheck": "node --stack-size=8192 node_modules/typescript/bin/tsc --noEmit",
    "build:web": "expo export --platform web --output-dir dist",
    "start": "expo start",
    "start:mobile": "node scripts/start-expo-mobile.mjs",
    "start:mobile:tunnel": "node scripts/start-expo-mobile.mjs --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "private": true
}
