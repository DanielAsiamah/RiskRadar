# Expo frontend
EXPO_PUBLIC_API_BASE_URL=https://your-backend-domain.onrender.com
EXPO_PUBLIC_API_PORT=3001

# Backend runtime
HOST=0.0.0.0
PORT=3001
NODE_ENV=production
RISKRADAR_DATA_DIR=./backend/cache
STATE_DRIVER=json
SQLITE_STATE_FILE=./backend/cache/riskradar-state.sqlite
ADMIN_API_KEY=change-me-before-using-admin-endpoints
MAX_REQUEST_BODY_BYTES=32768
ADMIN_MAX_REQUEST_BODY_BYTES=2097152

# CORS and public traffic protection
CORS_ALLOW_ORIGIN=https://your-frontend-domain.example
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=180

# Upstream resilience
UPSTREAM_TIMEOUT_MS=15000
UPSTREAM_RETRY_COUNT=1
UPSTREAM_RETRY_DELAY_MS=350
STALE_IF_ERROR_ENABLED=true
STALE_CACHE_MAX_AGE_MS=604800000

# Cache and persistence
CACHE_TTL_MS=900000
GEOCODE_CACHE_TTL_MS=86400000
CRIME_CACHE_TTL_MS=21600000
CACHE_MAX_ENTRIES=500
PERSISTENT_CACHE_ENABLED=true
ANALYSIS_SNAPSHOTS_ENABLED=true
ANALYSIS_CACHE_ENABLED=true
SEARCH_PRESETS_ENABLED=true
